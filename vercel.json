{
  "buildCommand": "cd server && npx prisma generate && cd ../web && npm run build",
  "outputDirectory": "web/dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "https://haireco.onrender.com/api/$1" },
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ]
}
